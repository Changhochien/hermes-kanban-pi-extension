{
  "name": "@hermes/pi-kanban",
  "version": "2.1.0",
  "description": "Pi agent extension for Hermes multi-agent Kanban board integration. Supports multi-board, worker context injection, and health tools.",
  "main": "src/index.ts",
  "type": "module",
  "keywords": [
    "pi-extension",
    "pi-package",
    "hermes",
    "kanban",
    "multi-agent"
  ],
  "pi": {
    "extensions": ["./src/index.ts"],
    "skills": ["./skills/hermes-kanban"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pi": ">=1.0.0"
  },
  "author": "",
  "license": "MIT"
}
